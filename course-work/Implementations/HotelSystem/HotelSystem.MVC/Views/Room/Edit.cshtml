@using HotelSystem.MVC.Models.Room
@model RoomViewModel

<h2>Редактирай стая</h2>
<form asp-action="Edit" asp-route-id="@Model.RoomId" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="RoomType" class="form-label">Тип</label>
        <input asp-for="RoomType" class="form-control" />
        <span asp-validation-for="RoomType" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PricePerNight" class="form-label">Цена на нощ</label>
        <input asp-for="PricePerNight" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="PricePerNight" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Capacity" class="form-label">Капацитет</label>
        <input asp-for="Capacity" class="form-control" type="number" />
        <span asp-validation-for="Capacity" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Запази</button>
    <a asp-action="Index" class="btn btn-secondary">Отказ</a>
</form>