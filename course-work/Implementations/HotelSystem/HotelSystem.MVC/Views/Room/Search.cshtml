@using HotelSystem.MVC.Models.Room
@model List<RoomViewModel>

<h2>Търсене на стаи</h2>
<form asp-action="Search" method="get">
    <div class="mb-3">
        <label class="form-label">Тип стая</label>
        <input name="roomType" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Свободна</label>
        <select name="isAvailable" class="form-control">
            <option value="">Всички</option>
            <option value="true">Да</option>
            <option value="false">Не</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Търси</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>

@if (Model != null && Model.Any())
{
    <table class="table mt-3">
        <thead>
            <tr>
                <th>Номер</th>
                <th>Тип</th>
                <th>Цена</th>
                <th>Свободна</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model)
            {
                <tr>
                    <td>@room.RoomType</td>
                    <td>@room.PricePerNight</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@room.RoomId" class="btn btn-info btn-sm">Детайли</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}