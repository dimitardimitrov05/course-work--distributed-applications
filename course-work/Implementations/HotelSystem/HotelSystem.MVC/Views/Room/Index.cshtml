@using HotelSystem.MVC.Models.Room
@model List<RoomViewModel>

<h2>Стаи</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Добави стая</a>
<a asp-action="Search" class="btn btn-secondary mb-3">Търсене</a>

<table class="table">
    <thead>
        <tr>
            <th>Тип</th>
            <th>Цена</th>
            <th>Капацитет</th>
            <th>Свободна</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var room in Model)
        {
            <tr>
                <td>@room.RoomType</td>
                <td>@room.PricePerNight</td>
                <td>@room.Capacity</td>
                <td>
                    <a asp-action="Details" asp-route-id="@room.RoomId" class="btn btn-info btn-sm">Детайли</a>
                    <a asp-action="Edit" asp-route-id="@room.RoomId" class="btn btn-warning btn-sm">Редактирай</a>
                    <a asp-action="Delete" asp-route-id="@room.RoomId" class="btn btn-danger btn-sm">Изтрий</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    @if (ViewBag.Page > 1)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.Page - 1)" class="btn btn-secondary">Предишна</a>
    }
    <span>Страница @ViewBag.Page</span>
    @if (ViewBag.Page * ViewBag.PageSize < ViewBag.TotalItems)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.Page + 1)" class="btn btn-secondary">Следваща</a>
    }
</div>