@using HotelSystem.MVC.Models.Hotel
@model List<HotelViewModel>

<h2>Хотели</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Добави хотел</a>
<a asp-action="Search" class="btn btn-secondary mb-3">Търсене</a>

<table class="table">
    <thead>
        <tr>
            <th>Име</th>
            <th>Град</th>
            <th>Рейтинг</th>
            <th>Телефон</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var hotel in Model)
        {
            <tr>
                <td>@hotel.Name</td>
                <td>@hotel.City</td>
                <td>@hotel.StarRating</td>
                <td>@hotel.PhoneNumber</td>
                <td>
                    <a asp-action="Details" asp-route-id="@hotel.HotelId" class="btn btn-info btn-sm">Детайли</a>
                    <a asp-action="Edit" asp-route-id="@hotel.HotelId" class="btn btn-warning btn-sm">Редактирай</a>
                    <a asp-action="Delete" asp-route-id="@hotel.HotelId" class="btn btn-danger btn-sm">Изтрий</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    @if (ViewBag.Page > 1)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.Page - 1)" class="btn btn-secondary">Предишна</a>
    }
    <span>Страница @ViewBag.Page</span>
    @if (ViewBag.Page * ViewBag.PageSize < ViewBag.TotalItems)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.Page + 1)" class="btn btn-secondary">Следваща</a>
    }
</div>