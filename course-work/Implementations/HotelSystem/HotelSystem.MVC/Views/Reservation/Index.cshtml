@using HotelSystem.MVC.Models.Reservation
@model List<ReservationViewModel>

<h2>Резервации</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Добави резервация</a>
<a asp-action="Search" class="btn btn-secondary mb-3">Търсене</a>

<table class="table">
    <thead>
        <tr>
            <th>Хотел</th>
            <th>Потребител</th>
            <th>Настаняване</th>
            <th>Напускане</th>
            <th>Цена</th>
            <th>Статус</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reservation in Model)
        {
            <tr>
                <td>@reservation.HotelName</td>
                <td>@reservation.Username</td>
                <td>@reservation.CheckInDate.ToShortDateString()</td>
                <td>@reservation.CheckOutDate.ToShortDateString()</td>
                <td>@reservation.TotalPrice лв.</td>
                <td>@reservation.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@reservation.ReservationId" class="btn btn-info btn-sm">Детайли</a>
                    <a asp-action="Edit" asp-route-id="@reservation.ReservationId" class="btn btn-warning btn-sm">Редактирай</a>
                    <a asp-action="Delete" asp-route-id="@reservation.ReservationId" class="btn btn-danger btn-sm">Изтрий</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    @if (ViewBag.Page > 1)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.Page - 1)" class="btn btn-secondary">Предишна</a>
    }
    <span>Страница @ViewBag.Page</span>
    @if (ViewBag.Page * ViewBag.PageSize < ViewBag.TotalItems)
    {
        <a asp-action="Index" asp-route-page="@(ViewBag.Page + 1)" class="btn btn-secondary">Следваща</a>
    }
</div>